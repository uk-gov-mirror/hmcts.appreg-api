#!groovy

properties([
  parameters([
    booleanParam(name: 'SKIP_TESTS', defaultValue: false, description: 'Skip all tests'),
    booleanParam(name: 'SKIP_SONAR', defaultValue: false, description: 'Skip sonar'),
    booleanParam(name: 'FAIL_FAST', defaultValue: false, description: 'Should tests fail fast'),
  ])
])

@Library("Infrastructure")

def type = "java"
def product = "appreg"
def component = "api"

import uk.gov.hmcts.contino.GradleBuilder
import uk.gov.hmcts.contino.GithubAPI

def branchesToSync = ['demo', 'ithc']

def secrets = [
        'appreg-${env}': [
                secret('POSTGRES-USER', 'DB_USER'),
                secret('POSTGRES-PASS', 'DB_PASSWORD'),
                secret('POSTGRES-HOST', 'DB_HOST'),
                secret('POSTGRES-PORT', 'DB_PORT'),
                secret('POSTGRES-DATABASE', 'DB_NAME'),
        ]
]

static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [$class     : 'AzureKeyVaultSecret',
     secretType : 'Secret',
     name       : secretName,
     version    : '',
     envVariable: envVar
    ]
}

/**
 * determines the development environment deployment based on the PR labels. If the label
 * "enable_portal" is present then the portal will be deployed in the PR environment.
 * If the label "enable_portal:pr-<image_suffix>" is present then the portal will
 * be deployed with the specified image suffix in the PR environment.
 */
def determineDevEnvironmentDeployment() {
  env.DEV_ENABLE_PORTAL = false
  env.DEV_PORTAL_IMAGE = "latest"

  echo "1 - env.DEV_ENABLE_PORTAL: ${env.DEV_ENABLE_PORTAL}"

  def githubApi = new GithubAPI(this)
  for (label in githubApi.getLabelsbyPattern(env.BRANCH_NAME, "enable_portal")) {

    // If the portal label exists then load the portal
    if (label ==~ /enable_portal.*/) {
      env.DEV_ENABLE_PORTAL = true

      if (label ==~ /enable_portal:pr-.*/) {
        env.DEV_PORTAL_IMAGE = label.replace("enable_portal:", "")
        echo "Portal image suffix: ${env.DEV_PORTAL_IMAGE}"
      }
      echo "Deploying portal (${env.DEV_PORTAL_IMAGE}) instance in PR environment"
    }
  }

  echo "2 - env.DEV_ENABLE_PORTAL: ${env.DEV_ENABLE_PORTAL}"
}

withPipeline(type, product, component) {
  env.SKIP_TESTS = params.SKIP_TESTS
  env.SKIP_SONAR = params.SKIP_SONAR
  env.FAIL_FAST = params.FAIL_FAST

  echo "SKIP_TESTS: ${env.SKIP_TESTS}"
  echo "SKIP_SONAR: ${env.SKIP_SONAR}"
  echo "FAIL_FAST: ${env.FAIL_FAST}"

  loadVaultSecrets(secrets)
  enableSlackNotifications('#appreg-builds')

  syncBranchesWithMaster(branchesToSync)


  before('dbmigrate:demo') {
    sh("./gradlew --no-daemon --init-script init.gradle assemble")
  }

  before('dbmigrate:test') {
    sh("./gradlew --no-daemon --init-script init.gradle assemble")
  }

  before('dbmigrate:ithc') {
    sh("./gradlew --no-daemon --init-script init.gradle assemble")
  }

  before('dbmigrate:demo') {
    sh("./gradlew --no-daemon --init-script init.gradle assemble")
  }

  before('dbmigrate:test') {
    sh("./gradlew --no-daemon --init-script init.gradle assemble")
  }

  before('dbmigrate:ithc') {
    sh("./gradlew --no-daemon --init-script init.gradle assemble")
  }

  before('akschartsinstall') {
    onPR {
      determineDevEnvironmentDeployment()
    }
  }
}
