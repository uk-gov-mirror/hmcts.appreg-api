static LinkedHashMap<String, Object> secret(String secretName, String envVar) {
    [$class     : 'AzureKeyVaultSecret',
     secretType : 'Secret',
     name       : secretName,
     version    : '',
     envVariable: envVar
    ]
}

withPipeline(type, product, component) {
    env.SKIP_TESTS = params.SKIP_TESTS
    env.SKIP_SONAR = params.SKIP_SONAR
    env.FAIL_FAST = params.FAIL_FAST

    echo "SKIP_TESTS: ${env.SKIP_TESTS}"
    echo "SKIP_SONAR: ${env.SKIP_SONAR}"
    echo "FAIL_FAST: ${env.FAIL_FAST}"

    loadVaultSecrets(secrets)
    enableSlackNotifications('#appreg-builds')

    syncBranchesWithMaster(branchesToSync)
}

/**
 * determines the development environment deployment based on the PR labels. If the label
 * "enable_portal" is present then the portal will be deployed in the PR environment.
 * If the label "enable_portal:pr-<image_suffix>" is present then the portal will
 * be deployed with the specified image suffix in the PR environment.
 */
def determineDevEnvironmentDeployment() {
  env.DEV_ENABLE_DARTS_PORTAL = false
  env.DEV_PORTAL_IMAGE_SUFFIX = "latest"

  echo "1 - env.DEV_ENABLE_PORTAL: ${env.DEV_ENABLE_DARTS_PORTAL}"

  def githubApi = new GithubAPI(this)
    for (label in githubApi.getLabelsbyPattern(env.BRANCH_NAME, "enable_portal_")) {

      // If the portal label exists then load the portal
      if (label ==~ /enable_portal_.*/) {
        env.DEV_ENABLE_PORTAL = true

        if (label ==~ /enable_portal:pr-.*/) {
          env.DEV_PORTAL_IMAGE = label.replace("enable_portal:", "")
          echo "DARTS portal image suffix: ${env.DEV_PORTAL_IMAGE}"
        }
        echo "Deploying portal (${env.DEV_PORTAL_IMAGE}) instance in PR environment"
      }
    }

  echo "2 - env.DEV_ENABLE_DARTS_PORTAL: ${env.DEV_ENABLE_DARTS_PORTAL}"
}

  afterFailure('test') {
    junit testResults: '**/test-results/integration/*.xml'
  }

